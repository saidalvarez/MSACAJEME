{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Taller MSA Cajeme",
  "version": "1.0.0",
  "identifier": "com.autoservice.cajeme",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Taller MSA Cajeme v1.0",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' asset: https: data:; connect-src 'self' http://localhost:3001 http://127.0.0.1:3001 ws://localhost:3001 ws://127.0.0.1:3001"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://gist.githubusercontent.com/saidalvarez/851015e838ef7f4877b550643493b3a0/raw/update.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZBRThGRTc4NjFGQ0UwQ0YKUldUUDRQeGhlUDdvK3FxY3RqdWJNNi9ycTlmazBiQ2xsUkdmQVNNNjV6aWhleVRHY0hVQkYwc2YK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis"
    ],
    "resources": [
      "bin/msa-server.exe"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both",
        "displayLanguageSelector": false
      },
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}