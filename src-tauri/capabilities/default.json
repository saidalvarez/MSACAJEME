{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for MSA Cajeme desktop app",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "http:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://localhost:3001/*" },
        { "url": "http://127.0.0.1:3001/*" },
        { "url": "https://github.com/saidalvarez/*" },
        { "url": "https://objects.githubusercontent.com/*" }
      ]
    },
    "updater:default",
    "process:default"
  ]
}
