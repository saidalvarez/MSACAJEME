{
  "name": "msa-cajeme-backend",
  "version": "1.0.0",
  "description": "Professional Backend for MSA Cajeme",
  "main": "servidor.ts",
  "bin": "dist/servidor.js",
  "pkg": {
    "assets": [
      "dist/**/*",
      "node_modules/sequelize/**/*",
      "node_modules/pg/**/*",
      "node_modules/node-cron/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ]
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/servidor.js",
    "dev": "ts-node-dev --respawn --transpile-only servidor.ts"
  },
  "dependencies": {
    "@types/express-rate-limit": "^5.1.3",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "pg": "^8.13.1",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.5",
    "socket.io": "^4.8.3",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/node": "^22.13.5",
    "@types/node-cron": "^3.0.11",
    "@types/winston": "^2.4.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3"
  }
}
